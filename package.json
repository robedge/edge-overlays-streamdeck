{
  "name": "edge-overlays-streamdeck",
  "version": "1.0.0",
  "description": "Stream Deck plugin for controlling Edge Overlays",
  "author": "Rob Edgell",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.edgeoverlays.iracing\""
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/ws": "^8.5.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  }
}
